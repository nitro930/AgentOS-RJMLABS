generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==========================================
// LAYER 1: FOUNDATION
// ==========================================

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  category  String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// LAYER 2: MEMORY (Omi + Obsidian)
// ==========================================

model MemoryEntry {
  id        String   @id @default(cuid())
  type      String   // "conversation", "output", "insight", "task", "reference"
  title     String
  content   String
  tags      String   @default("[]") // JSON array of tags
  source    String?  // Which agent produced this
  agentId   String?  // Reference to the agent that created it
  path      String?  // Obsidian-style vault path e.g. "vault/insights/2024"
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent Agent? @relation(fields: [agentId], references: [id])
}

// ==========================================
// LAYER 3: BRAIN (Routed Models)
// ==========================================

model ModelConfig {
  id          String   @id @default(cuid())
  name        String   @unique // e.g. "gpt-4o", "claude-3.5-sonnet"
  provider    String   // "openai", "anthropic", "local", "z-ai"
  modelId     String   // The actual model identifier for API calls
  isActive    Boolean  @default(true)
  costPer1k   Float    @default(0) // Cost per 1k tokens
  maxTokens   Int      @default(4096)
  capabilities String  @default("[]") // JSON array: ["chat", "code", "vision"]
  priority    Int      @default(0) // Higher = preferred
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RoutingRule {
  id          String   @id @default(cuid())
  name        String
  condition   String   // JSON: {"task_type": "code", "priority": "high"}
  modelId     String   // Route to this model config
  isActive    Boolean  @default(true)
  priority    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// LAYER 4: AGENTS
// ==========================================

model Agent {
  id          String   @id @default(cuid())
  name        String   @unique
  type        String   // "hermes", "openclaw", "claude-code", "custom"
  description String
  status      String   @default("idle") // "idle", "running", "error", "paused"
  modelId     String?  // Assigned model
  config      String   @default("{}") // JSON config for the agent
  avatar      String?  // Emoji or icon identifier
  color       String   @default("#6366f1") // Brand color
  tasksCompleted Int   @default(0)
  tasksFailed    Int   @default(0)
  lastActiveAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memories    MemoryEntry[]
  tasks       AgentTask[]
  outputs     AgentOutput[]
}

model AgentTask {
  id          String   @id @default(cuid())
  agentId     String
  title       String
  description String
  status      String   @default("pending") // "pending", "running", "completed", "failed"
  priority    String   @default("medium") // "low", "medium", "high", "critical"
  input       String   @default("{}") // JSON task input
  output      String?  // JSON task output
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id])
}

// ==========================================
// LAYER 5: COMMAND CENTER (Mission Control)
// ==========================================

model CommandLog {
  id        String   @id @default(cuid())
  command   String
  source    String   // "user", "agent", "system"
  result    String?
  status    String   @default("executed") // "executed", "failed", "pending"
  createdAt DateTime @default(now())
}

// ==========================================
// LAYER 6: PRODUCTION SURFACES
// ==========================================

model Workspace {
  id          String   @id @default(cuid())
  name        String
  type        String   // "studio", "seo", "goals", "workspace"
  description String?
  config      String   @default("{}") // JSON workspace config
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Goal {
  id          String   @id @default(cuid())
  title       String
  description String
  status      String   @default("active") // "active", "completed", "paused", "archived"
  progress    Int      @default(0) // 0-100
  priority    String   @default("medium")
  dueDate     DateTime?
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// LAYER 7: LOOP (Output Writeback)
// ==========================================

model AgentOutput {
  id          String   @id @default(cuid())
  agentId     String
  type        String   // "text", "code", "file", "insight", "action"
  title       String
  content     String
  routedTo    String   @default("[]") // JSON: where this output was routed
  memoryId    String?  // If written back to memory
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id])
}

// ==========================================
// ANALYTICS & ACTIVITY
// ==========================================

model ActivityEvent {
  id        String   @id @default(cuid())
  type      String   // "agent_start", "agent_complete", "memory_write", "output_route", etc.
  source    String?  // Agent ID or "system"
  detail    String?  // JSON detail
  createdAt DateTime @default(now())
}

// ==========================================
// WORKFLOW / PIPELINE BUILDER
// ==========================================

model Workflow {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("draft") // "draft", "active", "paused", "completed", "archived"
  steps       String   @default("[]") // JSON: ordered array of {agentId, action, inputMapping, outputKey}
  triggerType String   @default("manual") // "manual", "schedule", "webhook", "event"
  triggerConfig String @default("{}") // JSON: cron expression, webhook URL, event filter
  lastRunAt   DateTime?
  runCount    Int      @default(0)
  successRate Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// SCHEDULER
// ==========================================

model ScheduledTask {
  id          String   @id @default(cuid())
  name        String
  agentId     String?
  workflowId  String?
  cronExpr    String   // e.g. "*/5 * * * *", "0 9 * * 1-5"
  status      String   @default("active") // "active", "paused", "error"
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  runCount    Int      @default(0)
  failCount   Int      @default(0)
  taskType    String   @default("agent") // "agent", "workflow", "command"
  taskConfig  String   @default("{}") // JSON: specific task parameters
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// NOTIFICATIONS
// ==========================================

model Notification {
  id        String   @id @default(cuid())
  type      String   // "info", "success", "warning", "error", "agent", "system"
  title     String
  message   String
  source    String?  // Agent ID or "system"
  isRead    Boolean  @default(false)
  actionUrl String?  // URL to navigate when clicked
  createdAt DateTime @default(now())
}

// ==========================================
// COST & USAGE TRACKING
// ==========================================

model CostEntry {
  id          String   @id @default(cuid())
  agentId     String?
  modelId     String?
  tokensIn    Int      @default(0)
  tokensOut   Int      @default(0)
  cost        Float    @default(0)
  taskType    String?  // "chat", "code", "research", etc.
  metadata    String   @default("{}") // JSON: additional context
  createdAt   DateTime @default(now())
}

model BudgetAlert {
  id          String   @id @default(cuid())
  name        String
  limitAmount Float    // Monthly budget limit
  currentSpend Float   @default(0)
  period      String   @default("monthly") // "daily", "weekly", "monthly"
  isActive    Boolean  @default(true)
  alertedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==========================================
// LAYER 1: FOUNDATION
// ==========================================

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  category  String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// LAYER 2: MEMORY (Omi + Obsidian)
// ==========================================

model MemoryEntry {
  id        String   @id @default(cuid())
  type      String   // "conversation", "output", "insight", "task", "reference"
  title     String
  content   String
  tags      String   @default("[]") // JSON array of tags
  source    String?  // Which agent produced this
  agentId   String?  // Reference to the agent that created it
  path      String?  // Obsidian-style vault path e.g. "vault/insights/2024"
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent Agent? @relation(fields: [agentId], references: [id])
}

// ==========================================
// LAYER 3: BRAIN (Routed Models)
// ==========================================

model ModelConfig {
  id          String   @id @default(cuid())
  name        String   @unique // e.g. "gpt-4o", "claude-3.5-sonnet"
  provider    String   // "openai", "anthropic", "local", "z-ai"
  modelId     String   // The actual model identifier for API calls
  isActive    Boolean  @default(true)
  costPer1k   Float    @default(0) // Cost per 1k tokens
  maxTokens   Int      @default(4096)
  capabilities String  @default("[]") // JSON array: ["chat", "code", "vision"]
  priority    Int      @default(0) // Higher = preferred
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RoutingRule {
  id          String   @id @default(cuid())
  name        String
  condition   String   // JSON: {"task_type": "code", "priority": "high"}
  modelId     String   // Route to this model config
  isActive    Boolean  @default(true)
  priority    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// LAYER 4: AGENTS
// ==========================================

model Agent {
  id          String   @id @default(cuid())
  name        String   @unique
  type        String   // "hermes", "openclaw", "claude-code", "custom"
  description String
  status      String   @default("idle") // "idle", "running", "error", "paused"
  modelId     String?  // Assigned model
  config      String   @default("{}") // JSON config for the agent
  avatar      String?  // Emoji or icon identifier
  color       String   @default("#6366f1") // Brand color
  tasksCompleted Int   @default(0)
  tasksFailed    Int   @default(0)
  lastActiveAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memories    MemoryEntry[]
  tasks       AgentTask[]
  outputs     AgentOutput[]
}

model AgentTask {
  id          String   @id @default(cuid())
  agentId     String
  title       String
  description String
  status      String   @default("pending") // "pending", "running", "completed", "failed"
  priority    String   @default("medium") // "low", "medium", "high", "critical"
  input       String   @default("{}") // JSON task input
  output      String?  // JSON task output
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id])
}

// ==========================================
// LAYER 5: COMMAND CENTER (Mission Control)
// ==========================================

model CommandLog {
  id        String   @id @default(cuid())
  command   String
  source    String   // "user", "agent", "system"
  result    String?
  status    String   @default("executed") // "executed", "failed", "pending"
  createdAt DateTime @default(now())
}

// ==========================================
// LAYER 6: PRODUCTION SURFACES
// ==========================================

model Workspace {
  id          String   @id @default(cuid())
  name        String
  type        String   // "studio", "seo", "goals", "workspace"
  description String?
  config      String   @default("{}") // JSON workspace config
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Goal {
  id          String   @id @default(cuid())
  title       String
  description String
  status      String   @default("active") // "active", "completed", "paused", "archived"
  progress    Int      @default(0) // 0-100
  priority    String   @default("medium")
  dueDate     DateTime?
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// LAYER 7: LOOP (Output Writeback)
// ==========================================

model AgentOutput {
  id          String   @id @default(cuid())
  agentId     String
  type        String   // "text", "code", "file", "insight", "action"
  title       String
  content     String
  routedTo    String   @default("[]") // JSON: where this output was routed
  memoryId    String?  // If written back to memory
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id])
}

// ==========================================
// ANALYTICS & ACTIVITY
// ==========================================

model ActivityEvent {
  id        String   @id @default(cuid())
  type      String   // "agent_start", "agent_complete", "memory_write", "output_route", etc.
  source    String?  // Agent ID or "system"
  detail    String?  // JSON detail
  createdAt DateTime @default(now())
}

// ==========================================
// WORKFLOW / PIPELINE BUILDER
// ==========================================

model Workflow {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("draft") // "draft", "active", "paused", "completed", "archived"
  steps       String   @default("[]") // JSON: ordered array of {agentId, action, inputMapping, outputKey}
  triggerType String   @default("manual") // "manual", "schedule", "webhook", "event"
  triggerConfig String @default("{}") // JSON: cron expression, webhook URL, event filter
  lastRunAt   DateTime?
  runCount    Int      @default(0)
  successRate Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// SCHEDULER
// ==========================================

model ScheduledTask {
  id          String   @id @default(cuid())
  name        String
  agentId     String?
  workflowId  String?
  cronExpr    String   // e.g. "*/5 * * * *", "0 9 * * 1-5"
  status      String   @default("active") // "active", "paused", "error"
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  runCount    Int      @default(0)
  failCount   Int      @default(0)
  taskType    String   @default("agent") // "agent", "workflow", "command"
  taskConfig  String   @default("{}") // JSON: specific task parameters
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// NOTIFICATIONS
// ==========================================

model Notification {
  id        String   @id @default(cuid())
  type      String   // "info", "success", "warning", "error", "agent", "system"
  title     String
  message   String
  source    String?  // Agent ID or "system"
  isRead    Boolean  @default(false)
  actionUrl String?  // URL to navigate when clicked
  createdAt DateTime @default(now())
}

// ==========================================
// COST & USAGE TRACKING
// ==========================================

model CostEntry {
  id          String   @id @default(cuid())
  agentId     String?
  modelId     String?
  tokensIn    Int      @default(0)
  tokensOut   Int      @default(0)
  cost        Float    @default(0)
  taskType    String?  // "chat", "code", "research", etc.
  metadata    String   @default("{}") // JSON: additional context
  createdAt   DateTime @default(now())
}

model BudgetAlert {
  id          String   @id @default(cuid())
  name        String
  limitAmount Float    // Monthly budget limit
  currentSpend Float   @default(0)
  period      String   @default("monthly") // "daily", "weekly", "monthly"
  isActive    Boolean  @default(true)
  alertedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// WEBHOOK INTEGRATIONS
// ==========================================

model Webhook {
  id          String   @id @default(cuid())
  name        String
  url         String   // The external URL to send/receive webhooks
  secret      String?  // Webhook signing secret for verification
  triggerEvents String @default("[]") // JSON: events that trigger this webhook
  sourceType  String   @default("incoming") // "incoming" (external → AgentOS) or "outgoing" (AgentOS → external)
  isActive    Boolean  @default(true)
  agentId     String?  // Agent to trigger on incoming webhook
  workflowId  String?  // Workflow to trigger on incoming webhook
  headers     String   @default("{}") // JSON: custom headers for outgoing webhooks
  lastTriggeredAt DateTime?
  triggerCount Int    @default(0)
  failCount   Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  webhookEvents WebhookEvent[]
}

model WebhookEvent {
  id        String   @id @default(cuid())
  webhookId String
  direction String   // "incoming" or "outgoing"
  payload   String   @default("{}") // JSON: the webhook payload
  status    String   @default("pending") // "pending", "success", "failed"
  response  String?  // JSON: response data or error
  createdAt DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id])
}

// ==========================================
// AGENT-TO-AGENT COMMUNICATION
// ==========================================

model AgentMessage {
  id          String   @id @default(cuid())
  fromAgentId String
  toAgentId   String
  messageType String   @default("message") // "message", "task_delegation", "context_share", "query", "response"
  content     String
  threadId    String?  // For grouping related messages
  priority    String   @default("normal") // "low", "normal", "high", "urgent"
  isRead      Boolean  @default(false)
  metadata    String   @default("{}") // JSON: additional context, attachments, references
  createdAt   DateTime @default(now())
}

// ==========================================
// BACKUP & RECOVERY
// ==========================================

model Backup {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   @default("full") // "full", "memory", "agents", "workflows", "config"
  size        Int      @default(0) // Size in bytes
  data        String   // JSON: the actual backup data
  version     String   @default("1.0")
  isAuto      Boolean  @default(false) // Auto-generated backup
  createdAt   DateTime @default(now())
}

// ==========================================
// TEMPLATE LIBRARY
// ==========================================

model Template {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String   @default("agent") // "agent", "workflow", "memory", "config"
  icon        String   @default("📋") // Emoji icon
  config      String   // JSON: the template configuration
  tags        String   @default("[]") // JSON: searchable tags
  isBuiltIn   Boolean  @default(true) // Built-in vs user-created
  useCount    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// VPS TERMINAL
// ==========================================

model TerminalSession {
  id          String   @id @default(cuid())
  name        String
  host        String   @default("localhost")
  port        Int      @default(22)
  username    String   @default("root")
  status      String   @default("disconnected") // "connected", "disconnected", "error"
  lastCommand String?
  commandCount Int    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TerminalCommand {
  id          String   @id @default(cuid())
  sessionId   String
  command     String
  output      String   @default("")
  exitCode    Int?
  duration    Int      @default(0) // ms
  createdAt   DateTime @default(now())
}

// ==========================================
// SECURITY VAULT (API Keys)
// ==========================================

model ApiKey {
  id          String   @id @default(cuid())
  name        String
  provider    String   // "openai", "anthropic", "z-ai", "custom"
  keyPreview  String   // Last 4 chars only for display
  keyEncrypted String  // Encrypted API key
  keyIV       String   // Initialization vector for decryption
  permissions String   @default("[]") // JSON: ["chat", "code", "vision", "admin"]
  usageCount  Int      @default(0)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AccessRule {
  id          String   @id @default(cuid())
  name        String
  resource    String   // "agents", "memory", "workflows", "terminal", "settings"
  action      String   // "read", "write", "execute", "admin"
  agentId     String?  // If null, applies to all agents
  isAllowed   Boolean  @default(true)
  conditions  String   @default("{}") // JSON: time-based, rate-limit, etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// AUDIT LOG
// ==========================================

model AuditLog {
  id          String   @id @default(cuid())
  action      String   // "create", "read", "update", "delete", "execute", "login", "api_call"
  resource    String   // "agent", "memory", "workflow", "api_key", "terminal", "system"
  resourceId  String?
  details     String   @default("{}") // JSON: before/after state, metadata
  source      String   @default("user") // "user", "agent", "system", "api"
  sourceId    String?  // Agent ID or user ID
  ipAddress   String?
  severity    String   @default("info") // "info", "warning", "critical"
  timestamp   DateTime @default(now())
}

// ==========================================
// AGENT PLAYGROUND
// ==========================================

model PlaygroundSession {
  id          String   @id @default(cuid())
  name        String
  agentId     String?
  modelId     String?
  status      String   @default("idle") // "idle", "running", "paused", "completed"
  input       String   @default("{}") // JSON: test input
  output      String?  // JSON: test output
  config      String   @default("{}") // JSON: override config
  iterations  Int      @default(0)
  tokensUsed  Int      @default(0)
  duration    Int      @default(0) // ms
  tags        String   @default("[]") // JSON: test tags
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// PLUGIN SYSTEM
// ==========================================

model Plugin {
  id          String   @id @default(cuid())
  name        String
  description String
  version     String   @default("1.0.0")
  author      String   @default("community")
  category    String   @default("utility") // "utility", "integration", "agent", "theme", "language"
  icon        String   @default("🧩")
  entryPoint  String   // Path or URL to plugin entry
  config      String   @default("{}") // JSON: plugin configuration
  permissions String   @default("[]") // JSON: required permissions
  hooks       String   @default("[]") // JSON: event hooks the plugin subscribes to
  isActive    Boolean  @default(false)
  isInstalled Boolean  @default(true)
  isBuiltIn   Boolean  @default(false)
  rating      Float    @default(0)
  installCount Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// SYSTEM HEALTH MONITOR
// ==========================================

model HealthMetric {
  id          String   @id @default(cuid())
  metric      String   // "cpu", "memory", "disk", "network_in", "network_out", "load", "uptime"
  value       Float
  unit        String   @default("%") // "%", "MB", "GB", "Mbps", "count"
  labels      String   @default("{}") // JSON: additional labels
  createdAt   DateTime @default(now())
}

model HealthAlert {
  id          String   @id @default(cuid())
  metric      String
  condition   String   // "gt", "lt", "eq", "gte", "lte"
  threshold   Float
  current     Float
  severity    String   @default("warning") // "warning", "critical"
  message     String
  isResolved  Boolean  @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
}

// ==========================================
// FILE MANAGER
// ==========================================

model FileEntry {
  id          String   @id @default(cuid())
  name        String
  path        String   // Full path on the VPS
  type        String   // "file", "directory", "symlink"
  size        Int      @default(0) // Bytes
  mimeType    String?  // "text/plain", "application/json", etc.
  permissions String   @default("644")
  owner       String   @default("root")
  isShared    Boolean  @default(false) // Shared with agents
  agentId     String?  // Agent that created/owns this file
  tags        String   @default("[]") // JSON: searchable tags
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// AGENT SKILLS / TOOLS
// ==========================================

model AgentSkill {
  id          String   @id @default(cuid())
  name        String
  description String
  type        String   // "function", "api_call", "shell_command", "code_execution", "web_search", "data_transform"
  icon        String   @default("⚡")
  config      String   @default("{}") // JSON: skill configuration
  parameters  String   @default("[]") // JSON: parameter schema
  returns     String   @default("{}") // JSON: return type schema
  isActive    Boolean  @default(true)
  isBuiltIn   Boolean  @default(false)
  useCount    Int      @default(0)
  lastUsedAt  DateTime?
  agentId     String?  // If null, available to all agents
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// MCP (MODEL CONTEXT PROTOCOL)
// ==========================================

model MCPServer {
  id            String   @id @default(cuid())
  name          String
  description   String?
  version       String   @default("1.0.0")
  transportType String   @default("stdio") // "stdio", "sse", "streamable-http"
  command       String?  // For stdio: e.g. "npx", "python"
  args          String   @default("[]") // JSON: command arguments
  envVars       String   @default("{}") // JSON: environment variables
  url           String?  // For SSE/HTTP: server URL
  headers       String   @default("{}") // JSON: custom headers for HTTP transport
  status        String   @default("disconnected") // "connected", "disconnected", "error", "connecting"
  lastConnectedAt DateTime?
  toolCount     Int      @default(0)
  resourceCount Int      @default(0)
  promptCount   Int      @default(0)
  requestCount  Int      @default(0)
  errorCount    Int      @default(0)
  isActive      Boolean  @default(true)
  autoConnect   Boolean  @default(false)
  tags          String   @default("[]") // JSON: searchable tags
  icon          String   @default("🔌")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tools     MCPTool[]
  resources MCPResource[]
  prompts   MCPPrompt[]
  executions MCPExecution[]
}

model MCPTool {
  id           String   @id @default(cuid())
  serverId     String
  name         String
  description  String?
  inputSchema  String   @default("{}") // JSON Schema for tool input
  annotations  String   @default("{}") // JSON: tool annotations (readOnlyHint, destructiveHint, etc.)
  isActive     Boolean  @default(true)
  useCount     Int      @default(0)
  lastUsedAt   DateTime?
  avgDuration  Int      @default(0) // Average execution time in ms
  errorRate    Float    @default(0) // Error rate 0-1
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  server MCPServer @relation(fields: [serverId], references: [id])

  @@unique([serverId, name])
}

model MCPResource {
  id           String   @id @default(cuid())
  serverId     String
  uri          String
  name         String
  description  String?
  mimeType     String?
  template     String?  // URI template for template resources
  isActive     Boolean  @default(true)
  accessCount  Int      @default(0)
  lastAccessedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  server MCPServer @relation(fields: [serverId], references: [id])

  @@unique([serverId, uri])
}

model MCPPrompt {
  id           String   @id @default(cuid())
  serverId     String
  name         String
  description  String?
  arguments    String   @default("[]") // JSON: prompt argument schema
  isActive     Boolean  @default(true)
  useCount     Int      @default(0)
  lastUsedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  server MCPServer @relation(fields: [serverId], references: [id])

  @@unique([serverId, name])
}

model MCPExecution {
  id          String   @id @default(cuid())
  serverId    String
  toolId      String?
  type        String   @default("tool") // "tool", "resource", "prompt"
  name        String   // Tool/resource/prompt name
  input       String   @default("{}") // JSON: execution input
  output      String?  // JSON: execution output
  status      String   @default("pending") // "pending", "running", "success", "error", "timeout"
  error       String?
  duration    Int      @default(0) // ms
  tokenCount  Int      @default(0) // Tokens used if applicable
  pipelineId  String?  // Reference to pipeline if part of one
  stepIndex   Int      @default(0) // Step index in pipeline
  agentId     String?  // Agent that triggered this
  createdAt   DateTime @default(now())
  completedAt DateTime?

  server MCPServer @relation(fields: [serverId], references: [id])
}

model MCPPipeline {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("draft") // "draft", "active", "running", "completed", "error"
  steps       String   @default("[]") // JSON: [{serverId, toolName, inputMapping, outputKey}]
  connections String   @default("[]") // JSON: [{fromStep, toStep, dataMapping}]
  inputSchema String   @default("{}") // JSON: pipeline input schema
  outputSchema String  @default("{}") // JSON: pipeline output schema
  runCount    Int      @default(0)
  lastRunAt   DateTime?
  avgDuration Int      @default(0) // Average pipeline execution time
  successRate Float    @default(0)
  isPublic    Boolean  @default(false) // Share with other agents
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// NOTIFICATION CHANNELS
// ==========================================

model NotificationChannel {
  id          String   @id @default(cuid())
  name        String
  type        String   // "email", "slack", "discord", "webhook", "telegram"
  config      String   @default("{}") // JSON: channel-specific config (webhook URL, email address, etc.)
  isActive    Boolean  @default(true)
  triggerEvents String @default("[]") // JSON: events that trigger this channel
  lastTriggeredAt DateTime?
  triggerCount Int    @default(0)
  failCount   Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  channelDeliveries ChannelDelivery[]
}

model ChannelDelivery {
  id          String   @id @default(cuid())
  channelId   String
  notificationId String?
  status      String   @default("pending") // "pending", "sent", "failed"
  payload     String   @default("{}") // JSON: delivered payload
  response    String?  // JSON: response from channel
  attempts    Int      @default(0)
  createdAt   DateTime @default(now())

  channel NotificationChannel @relation(fields: [channelId], references: [id])
}

// ==========================================
// AGENT SWARM
// ==========================================

model Swarm {
  id            String   @id @default(cuid())
  name          String
  description   String?
  status        String   @default("idle") // "idle", "active", "paused", "completed", "error"
  strategy      String   @default("queen") // "queen", "democratic", "consensus", "round-robin", "specialized"
  queenAgentId  String?  // Lead agent in queen strategy
  maxAgents     Int      @default(5)
  taskDecomposition String @default("auto") // "auto", "manual", "hybrid"
  consensusThreshold Float @default(0.6) // 0-1 for democratic/consensus strategies
  sharedMemory  Boolean  @default(true) // Whether agents share a memory space
  autoScale     Boolean  @default(false) // Auto-add agents based on workload
  totalTasks    Int      @default(0)
  completedTasks Int     @default(0)
  failedTasks   Int      @default(0)
  avgTaskDuration Int    @default(0) // ms
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  members      SwarmMember[]
  swarmTasks   SwarmTask[]
  decisions    SwarmDecision[]
}

model SwarmMember {
  id          String   @id @default(cuid())
  swarmId     String
  agentId     String
  role        String   @default("worker") // "queen", "worker", "scout", "specialist", "reviewer"
  status      String   @default("idle") // "idle", "busy", "error", "offline"
  tasksCompleted Int   @default(0)
  tasksFailed    Int   @default(0)
  contribution   Float @default(0) // 0-1 score
  joinedAt    DateTime @default(now())
  lastActiveAt DateTime?
  
  swarm Swarm @relation(fields: [swarmId], references: [id])
}

model SwarmTask {
  id            String   @id @default(cuid())
  swarmId       String
  parentTaskId  String?  // For decomposed subtasks
  assignedAgentId String?
  title         String
  description   String
  status        String   @default("pending") // "pending", "assigned", "in_progress", "review", "completed", "failed", "cancelled"
  priority      String   @default("medium") // "low", "medium", "high", "critical"
  input         String   @default("{}") // JSON
  output        String?  // JSON
  error         String?
  decomposition String   @default("[]") // JSON: child task IDs
  dependencies  String   @default("[]") // JSON: task IDs this depends on
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  swarm Swarm @relation(fields: [swarmId], references: [id])
}

model SwarmDecision {
  id          String   @id @default(cuid())
  swarmId     String
  type        String   // "task_assignment", "consensus_vote", "escalation", "strategy_change", "conflict_resolution"
  proposal    String   // JSON: the proposed action
  votes       String   @default("[]") // JSON: [{agentId, vote, reason}]
  result      String?  // JSON: the decided outcome
  status      String   @default("pending") // "pending", "voting", "approved", "rejected", "escalated"
  requiredVotes Int    @default(1)
  deadline    DateTime?
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?

  swarm Swarm @relation(fields: [swarmId], references: [id])
}

// ==========================================
// RAG KNOWLEDGE BASE
// ==========================================

model KnowledgeBase {
  id            String   @id @default(cuid())
  name          String
  description   String?
  type          String   @default("general") // "general", "code", "documentation", "research", "policies"
  embeddingModel String  @default("text-embedding-3-small")
  chunkStrategy String   @default("semantic") // "fixed", "semantic", "sentence", "paragraph"
  chunkSize     Int      @default(512) // tokens per chunk
  chunkOverlap  Int      @default(50) // overlap tokens
  documentCount Int      @default(0)
  chunkCount    Int      @default(0)
  totalTokens   Int      @default(0)
  isActive      Boolean  @default(true)
  icon          String   @default("📚")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  documents  KnowledgeDocument[]
  chunks     KnowledgeChunk[]
}

model KnowledgeDocument {
  id          String   @id @default(cuid())
  baseId      String
  title       String
  source      String   // "upload", "url", "api", "agent", "memory"
  sourceUrl   String?  // URL if from web
  mimeType    String   @default("text/plain")
  content     String   // Full document content
  summary     String?  // AI-generated summary
  metadata    String   @default("{}") // JSON: author, date, tags, etc.
  chunkCount  Int      @default(0)
  tokenCount  Int      @default(0)
  status      String   @default("processing") // "processing", "ready", "error", "archived"
  error       String?
  uploadedBy  String?  // Agent ID or "user"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  base KnowledgeBase @relation(fields: [baseId], references: [id])
  chunks KnowledgeChunk[]
}

model KnowledgeChunk {
  id          String   @id @default(cuid())
  documentId  String
  baseId      String
  content     String
  chunkIndex  Int      // Position in document
  tokenCount  Int      @default(0)
  embedding   String?  // JSON array of floats (simplified - production would use pgvector)
  metadata    String   @default("{}") // JSON: page number, section, headings
  relevance   Float    @default(0) // Cached relevance score
  accessCount Int      @default(0)
  createdAt   DateTime @default(now())

  document KnowledgeDocument @relation(fields: [documentId], references: [id])
  base     KnowledgeBase     @relation(fields: [baseId], references: [id])
}

model RetrievalQuery {
  id          String   @id @default(cuid())
  baseId      String
  query       String
  results     String   @default("[]") // JSON: [{chunkId, score, content}]
  topK        Int      @default(5)
  threshold   Float    @default(0.7) // Minimum similarity
  strategy    String   @default("hybrid") // "semantic", "keyword", "hybrid"
  agentId     String?  // Agent making the query
  duration    Int      @default(0) // ms
  createdAt   DateTime @default(now())
}

// ==========================================
// HUMAN-IN-THE-LOOP
// ==========================================

model ApprovalRequest {
  id            String   @id @default(cuid())
  title         String
  description   String
  type          String   @default("action") // "action", "deployment", "data_access", "config_change", "expense", "escalation"
  priority      String   @default("medium") // "low", "medium", "high", "critical"
  status        String   @default("pending") // "pending", "approved", "rejected", "expired", "cancelled", "escalated"
  agentId       String?  // Agent requesting approval
  workflowId    String?  // Related workflow
  actionData    String   @default("{}") // JSON: the action being requested
  riskLevel     String   @default("medium") // "low", "medium", "high", "critical"
  autoApprove   Boolean  @default(false) // Can be auto-approved based on rules
  autoReject    Boolean  @default(false)
  expiresAt     DateTime?
  reviewedBy    String?  // User who reviewed
  reviewedAt    DateTime?
  reviewNotes   String?
  rejectionReason String?
  escalationLevel Int    @default(0) // 0=direct, 1=manager, 2=admin
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ReviewGate {
  id            String   @id @default(cuid())
  name          String
  description   String?
  triggerType   String   @default("always") // "always", "risk_based", "cost_based", "action_type", "schedule"
  triggerConfig String   @default("{}") // JSON: conditions for triggering review
  actionTypes   String   @default("[]") // JSON: which action types require review
  riskThreshold Float    @default(0.5) // Risk level threshold (0-1) that triggers review
  costThreshold Float    @default(100) // Cost threshold that triggers review
  requireApproval Boolean @default(true) // true=approval needed, false=just notification
  autoExpireHours Int    @default(24) // Hours before request expires
  escalationChain String @default("[]") // JSON: [{level, reviewer, notify}]
  isActive      Boolean  @default(true)
  agentId       String?  // Apply to specific agent or null for all
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EscalationPolicy {
  id            String   @id @default(cuid())
  name          String
  description   String?
  level         Int      @default(1) // Escalation level
  triggerAfterMinutes Int @default(30) // Minutes before escalation
  notifyChannel String?  // Notification channel ID
  notifyUsers   String   @default("[]") // JSON: user IDs to notify
  autoAction    String   @default("none") // "none", "approve", "reject", "pause_agent"
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ==========================================
// GUARDRAILS & SAFETY
// ==========================================

model Guardrail {
  id            String   @id @default(cuid())
  name          String
  description   String?
  type          String   // "input_filter", "output_filter", "rate_limit", "content_policy", "scope_restriction", "cost_limit", "time_restriction"
  category      String   @default("safety") // "safety", "compliance", "performance", "cost", "privacy"
  isActive      Boolean  @default(true)
  severity      String   @default("medium") // "low", "medium", "high", "critical"
  action        String   @default("block") // "block", "warn", "log", "redirect", "sanitize"
  conditions    String   @default("{}") // JSON: trigger conditions
  patterns      String   @default("[]") // JSON: regex patterns or keywords to match
  rateLimitRps  Int?     // Requests per second (for rate_limit type)
  rateLimitRpm  Int?     // Requests per minute
  dailyLimit    Int?     // Daily action limit
  redirectTarget String? // Where to redirect if action is "redirect"
  agentId       String?  // Apply to specific agent or null for all
  tags          String   @default("[]")
  hitCount      Int      @default(0)
  lastHitAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  violations GuardrailViolation[]
}

model GuardrailViolation {
  id          String   @id @default(cuid())
  guardrailId String
  agentId     String?
  type        String   // The type of violation
  input       String?  // What triggered the violation
  output      String?  // What was blocked/filtered
  action      String   // What action was taken
  severity    String   @default("medium")
  isResolved  Boolean  @default(false)
  resolvedBy  String?
  resolvedAt  DateTime?
  metadata    String   @default("{}")
  createdAt   DateTime @default(now())

  guardrail Guardrail @relation(fields: [guardrailId], references: [id])
}

model ContentPolicy {
  id            String   @id @default(cuid())
  name          String
  description   String?
  type          String   @default("blocklist") // "blocklist", "allowlist", "pii_filter", "toxicity", "custom"
  rules         String   @default("[]") // JSON: [{pattern, action, replacement}]
  isActive      Boolean  @default(true)
  agentId       String?  // null = all agents
  violationCount Int    @default(0)
  lastViolationAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ==========================================
// AGENT EVALS
// ==========================================

model EvalSuite {
  id            String   @id @default(cuid())
  name          String
  description   String?
  type          String   @default("quality") // "quality", "safety", "performance", "accuracy", "regression", "benchmark"
  status        String   @default("draft") // "draft", "active", "running", "completed", "archived"
  agentId       String?  // Test specific agent or null for all
  passingScore  Float    @default(0.8) // 0-1 threshold
  lastRunAt     DateTime?
  lastScore     Float    @default(0)
  runCount      Int      @default(0)
  avgScore      Float    @default(0)
  bestScore     Float    @default(0)
  worstScore    Float    @default(1)
  isBuiltIn     Boolean  @default(false)
  icon          String   @default("🧪")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cases     EvalCase[]
  runs      EvalRun[]
}

model EvalCase {
  id          String   @id @default(cuid())
  suiteId     String
  name        String
  description String?
  input       String   @default("{}") // JSON: test input
  expectedOutput String @default("{}") // JSON: expected output
  evalCriteria String @default("[]") // JSON: [{metric, weight, threshold}]
  category    String   @default("general") // "general", "edge_case", "safety", "performance"
  difficulty  String   @default("medium") // "easy", "medium", "hard"
  isRequired  Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  suite EvalSuite @relation(fields: [suiteId], references: [id])
  results EvalResult[]
}

model EvalRun {
  id          String   @id @default(cuid())
  suiteId     String
  agentId     String?
  status      String   @default("running") // "running", "completed", "failed", "cancelled"
  totalCases  Int      @default(0)
  passedCases Int      @default(0)
  failedCases Int      @default(0)
  score       Float    @default(0) // 0-1
  duration    Int      @default(0) // ms
  config      String   @default("{}") // JSON: run configuration
  startedAt   DateTime @default(now())
  completedAt DateTime?

  suite EvalSuite @relation(fields: [suiteId], references: [id])
  results EvalResult[]
}

model EvalResult {
  id          String   @id @default(cuid())
  runId       String
  caseId      String
  status      String   @default("pending") // "pending", "passed", "failed", "error", "skipped"
  actualOutput String? // JSON: actual output
  score       Float    @default(0)
  metrics     String   @default("{}") // JSON: {metricName: score}
  error       String?
  duration    Int      @default(0) // ms
  createdAt   DateTime @default(now())

  run  EvalRun  @relation(fields: [runId], references: [id])
  case EvalCase @relation(fields: [caseId], references: [id])
}

// ==========================================
// OBSERVABILITY & TRACING
// ==========================================

model Trace {
  id            String   @id @default(cuid())
  name          String
  description   String?
  status        String   @default("running") // "running", "completed", "error", "timeout"
  agentId       String?
  workflowId    String?
  swarmId       String?
  totalSpans    Int      @default(0)
  errorSpans    Int      @default(0)
  totalDuration Int      @default(0) // ms
  tokenUsage    Int      @default(0)
  costUsd       Float    @default(0)
  rootSpanId    String?
  metadata      String   @default("{}") // JSON
  startedAt     DateTime @default(now())
  completedAt   DateTime?

  spans TraceSpan[]
}

model TraceSpan {
  id          String   @id @default(cuid())
  traceId     String
  parentId    String?  // Parent span ID for nested spans
  name        String
  kind        String   @default("internal") // "internal", "client", "server", "producer", "consumer"
  status      String   @default("ok") // "ok", "error", "cancelled"
  agentId     String?
  modelId     String?
  input       String   @default("{}") // JSON: span input
  output      String?  // JSON: span output
  error       String?
  tokensIn    Int      @default(0)
  tokensOut   Int      @default(0)
  costUsd     Float    @default(0)
  duration    Int      @default(0) // ms
  startedAt   DateTime @default(now())
  completedAt DateTime?
  
  trace Trace @relation(fields: [traceId], references: [id])
}

model ServiceGraph {
  id            String   @id @default(cuid())
  name          String
  type          String   // "agent", "model", "tool", "mcp_server", "workflow", "external"
  status        String   @default("healthy") // "healthy", "degraded", "down", "unknown"
  requestCount  Int      @default(0)
  errorCount    Int      @default(0)
  avgLatency    Int      @default(0) // ms
  p99Latency    Int      @default(0) // ms
  lastActiveAt  DateTime?
  metadata      String   @default("{}") // JSON
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ServiceEdge {
  id          String   @id @default(cuid())
  sourceId    String   // ServiceGraph ID
  targetId    String   // ServiceGraph ID
  callCount   Int      @default(0)
  errorCount  Int      @default(0)
  avgLatency  Int      @default(0) // ms
  dataFlow    String   @default("{}") // JSON: description of data exchanged
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

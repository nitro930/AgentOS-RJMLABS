// ==========================================
// AGENT VERSIONING
// ==========================================

model AgentVersion {
  id            String   @id @default(cuid())
  agentId       String
  version       Int      // Auto-incrementing version number
  config        String   // JSON: full agent config snapshot
  changeSummary String   @default("") // Human-readable summary of changes
  changeType    String   @default("update") // "create", "update", "config_change", "model_change", "restore"
  diffFrom      String   @default("{}") // JSON: diff from previous version
  author        String   @default("user") // "user", "agent", "system"
  isCurrent     Boolean  @default(false) // Is this the current active version?
  createdAt     DateTime @default(now())
}

// ==========================================
// ENVIRONMENT MANAGER
// ==========================================

model EnvVar {
  id          String   @id @default(cuid())
  key         String
  value       String   // Encrypted for secrets
  type        String   @default("string") // "string", "number", "boolean", "secret", "json"
  scope       String   @default("global") // "global", "agent", "workspace"
  scopeId     String?  // Agent or workspace ID if scoped
  description String?
  isSecret    Boolean  @default(false)
  isRequired  Boolean  @default(false)
  isActive    Boolean  @default(true)
  profileId   String?  // Associated profile
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EnvProfile {
  id          String   @id @default(cuid())
  name        String
  description String?
  isActive    Boolean  @default(false)
  variables   String   @default("{}") // JSON: key-value overrides for this profile
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// AGENT MARKETPLACE
// ==========================================

model MarketplaceAgent {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String   @default("general") // "general", "coding", "research", "writing", "data", "devops", "security"
  icon        String   @default("🏪")
  config      String   @default("{}") // JSON: agent configuration template
  author      String   @default("community")
  version     String   @default("1.0.0")
  tags        String   @default("[]") // JSON
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  installCount Int     @default(0)
  isOfficial  Boolean  @default(false) // Official RJMLABS agent
  isVerified  Boolean  @default(false)
  status      String   @default("published") // "published", "pending", "rejected", "archived"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reviews MarketplaceReview[]
}

model MarketplaceReview {
  id          String   @id @default(cuid())
  agentId     String
  userId      String   @default("anonymous")
  rating      Int      // 1-5
  title       String?
  content     String?
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())

  agent MarketplaceAgent @relation(fields: [agentId], references: [id])
}

// ==========================================
// DASHBOARD CUSTOMIZATION
// ==========================================

model DashboardWidget {
  id          String   @id @default(cuid())
  type        String   // "agent_status", "cost_summary", "memory_stats", "activity_feed", "health_monitor", "task_queue", "quick_actions", "recent_outputs"
  title       String
  description String?
  size        String   @default("medium") // "small", "medium", "large"
  position    Int      @default(0) // Order position
  column      Int      @default(0) // Grid column (0-3)
  row         Int      @default(0) // Grid row
  config      String   @default("{}") // JSON: widget-specific config
  isActive    Boolean  @default(true)
  isBuiltIn   Boolean  @default(true)
  icon        String   @default("📊")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// PROMPT LIBRARY (System Prompt Manager)
// ==========================================

model PromptTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String   @default("system") // "system", "persona", "task", "constraint", "formatting", "safety"
  content     String   // The actual prompt text with {{variables}}
  variables   String   @default("[]") // JSON: [{name, description, defaultValue, required}]
  tags        String   @default("[]")
  agentId     String?  // Assigned agent or null for shared
  isBuiltIn   Boolean  @default(false)
  useCount    Int      @default(0)
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DashboardPreference {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   // JSON string for complex values
  category  String   @default("layout") // "layout", "theme", "preferences"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// FEATURE FLAGS
// ==========================================

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  isEnabled   Boolean  @default(false)
  flagType    String   @default("boolean") // "boolean", "percentage", "variant"
  value       String   @default("true") // JSON: the flag value
  rules       String   @default("[]") // JSON: [{condition, value}]
  targetScope String   @default("all") // "all", "agents", "roles", "users"
  targetIds   String   @default("[]") // JSON: target entity IDs
  percentage  Int      @default(100) // For percentage rollout
  variants    String   @default("[]") // JSON: [{name, value, weight}]
  isActive    Boolean  @default(true)
  createdBy   String   @default("system")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  history FeatureFlagHistory[]
}

model FeatureFlagHistory {
  id        String   @id @default(cuid())
  flagId    String
  action    String   // "created", "updated", "toggled", "deleted", "rule_added", "rule_removed"
  oldValue  String   @default("") // JSON: previous value
  newValue  String   @default("") // JSON: new value
  changedBy String   @default("system")
  createdAt DateTime @default(now())

  flag FeatureFlag @relation(fields: [flagId], references: [id])
}

// ==========================================
// DOCKER MANAGER
// ==========================================

model DockerContainer {
  id          String   @id @default(cuid())
  name        String
  image       String
  status      String   @default("running") // "running", "stopped", "paused", "restarting", "dead"
  ports       String   @default("[]") // JSON: [{internal, external, protocol}]
  envVars     String   @default("{}") // JSON: environment variables
  networks    String   @default("[]") // JSON: connected network names
  volumes     String   @default("[]") // JSON: mounted volumes
  cpuPercent  Float    @default(0)
  memoryUsage Float    @default(0) // MB
  memoryLimit Float    @default(0) // MB
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
